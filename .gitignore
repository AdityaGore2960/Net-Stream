# ============================================================
#  NetStream — Root .gitignore
#  Covers the whole monorepo (root + client/ + server/)
# ============================================================

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm
.yarn-integrity
*.tgz
package-lock.json   # generated — keep if you rely on lockfiles; remove this line if you do
yarn.lock

# pnpm
.pnpm-store
.pnpm-debug.log*

# yarn v3 (keep specific dirs)
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ── Environment variables ────────────────────────────────────
# NEVER commit secrets. Commit .env.example instead.
.env
.env.*
!.env.example

# ── Build output ─────────────────────────────────────────────
dist/
build/
out/
.output/

# ── Vite ─────────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Next.js ──────────────────────────────────────────────────
.next/

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ── Test / coverage ──────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── OS artefacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json   # allow sharing recommended extensions
!.vscode/settings.json     # allow sharing project settings
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc tool caches ─────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.fusebox/
.dynamodb/
.serverless/
.firebase/
.svelte-kit/
.docusaurus/
.temp/
.grunt/
.tern-port
.vscode-test
.node_repl_history

# ── Runtime / diagnostic ─────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Docker ───────────────────────────────────────────────────
# Keep docker-compose.yml (it's source), ignore local overrides
docker-compose.override.yml
